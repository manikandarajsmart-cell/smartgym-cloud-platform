"use client";

type ClassItem = {
  _id?: string;
  className: string;
  trainer: string;
  schedule: string;
  duration: string;
  capacity: number;
};

type Props = {
  classes: ClassItem[];
  onEdit: (item: ClassItem) => void;
};

export default function ClassTable({
  classes,
  onEdit,
}: Props) {
console.log("Classes received:", classes);
  const handleDelete = async (id?: string) => {
    if (!id) return;

    const ok = confirm("Delete this class?");

    if (!ok) return;

    try {
      const res = await fetch(
        `${process.env.NEXT_PUBLIC_API_URL}/classes/${id}`,
        {
          method: "DELETE",
        }
      );

      const data = await res.json();

      if (data.success) {
        alert("Class Deleted Successfully!");
        window.location.reload();
      } else {
        alert("Delete Failed");
      }
    } catch (err) {
      console.error(err);
      alert("Server Error");
    }
  };

  return (
    <div
      style={{
        background: "#111",
        borderRadius: 12,
        padding: 20,
      }}
    >
      <h2>Classes List</h2>

      {classes.length === 0 ? (
        <p>No classes available.</p>
      ) : (
        <table
          style={{
            width: "100%",
            marginTop: 20,
            borderCollapse: "collapse",
          }}
        >
          <thead>
            <tr>
              <th align="left">Class</th>
              <th align="left">Trainer</th>
              <th align="left">Schedule</th>
              <th align="left">Duration</th>
              <th align="left">Capacity</th>
              <th align="left">Actions</th>
            </tr>
          </thead>

          <tbody>
            {classes.map((item) => (
              <tr key={item._id}>
                <td>{item.className}</td>
                <td>{item.trainer}</td>
                <td>{item.schedule}</td>
                <td>{item.duration}</td>
                <td>{item.capacity}</td>

              <td>
  <button
    style={{
      background: "#2563eb",
      color: "#fff",
      border: "none",
      padding: "8px 14px",
      borderRadius: 6,
      cursor: "pointer",
      marginRight: "10px",
    }}
  >
    Edit
  </button>

  <button
    onClick={() => handleDelete(item._id)}
    style={{
      background: "#dc2626",
      color: "#fff",
      border: "none",
      padding: "8px 14px",
      borderRadius: 6,
      cursor: "pointer",
    }}
  >
    Delete
  </button>
</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  );
}
