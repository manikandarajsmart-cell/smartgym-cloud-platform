*/

const ClassSchema = new mongoose.Schema({
  className: String,
  trainer: String,
  schedule: String,
  duration: String,
  capacity: Number,
  createdAt: {
    type: Date,
    default: Date.now,
  },
});

const Class = mongoose.model(
  "Class",
  ClassSchema
);

/*
=========================
CLASSES
=========================
*/

// Get all classes
app.get("/classes", async (req, res) => {
  try {
    const classes = await Class.find().sort({
      createdAt: -1,
    });

    res.json({
      success: true,
      classes,
    });
  } catch (error) {
    res.status(500).json({
      success: false,
      error: error.message,
    });
  }
});

// Add class
app.post("/classes", async (req, res) => {
  try {
    const newClass = await Class.create({
      className: req.body.className,
      trainer: req.body.trainer,
      schedule: req.body.schedule,
      duration: req.body.duration,
      capacity: Number(req.body.capacity || 0),
    });

    res.json({
      success: true,
      class: newClass,
    });
  } catch (error) {
    res.status(500).json({
      success: false,
      error: error.message,
    });
